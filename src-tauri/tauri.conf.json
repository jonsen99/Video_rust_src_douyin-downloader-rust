{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Douyin Downloader",
  "version": "0.0.3",
  "identifier": "com.douyin.downloader",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "抖音视频下载器",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: blob: http://127.0.0.1:39143; media-src 'self' https: data: blob: http://127.0.0.1:39143; font-src 'self' data:; connect-src 'self' https: wss: ws: ipc: http://127.0.0.1:39143;",
      "devCsp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: blob: http://127.0.0.1:39143; media-src 'self' https: data: blob: http://127.0.0.1:39143; font-src 'self' data:; connect-src 'self' https: wss: ws: ipc: http://127.0.0.1:39143;",
      "dangerousDisableAssetCspModification": [
        "script-src"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/anYuJia/douyin-downloader-rust/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEM0QzRUE5RDAyQjlEQjgKUldTNG5TdlFxVDQ5L2RFcVIydi9xU1YzUVhLb1lwWmRZTlc3V1NQOEIrSDZNenIraTRTZ1NFeU8K",
      "dialog": false
    }
  }
}
